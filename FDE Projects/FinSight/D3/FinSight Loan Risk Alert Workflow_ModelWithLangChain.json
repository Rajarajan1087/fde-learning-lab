    {
      "parameters": {
        "jsCode": "const app = $input.first().json.body;\n\nlet riskScore = 0;\nlet factors = [];\n\n// Rule 1\nif (app.credit_score < 550) {\n  riskScore += 2;\n  factors.push(\"Credit Score below 550\");\n}\n\n// Rule 2\nif (app.existing_emis >= 3) {\n  riskScore += 1;\n  factors.push(\"Existing EMIs >= 3\");\n}\n\n// Rule 3\nif (app.employment_status === \"Unemployed\") {\n  riskScore += 2;\n  factors.push(\"Applicant Unemployed\");\n}\n\n// Rule 4\nif (app.loan_amount > app.annual_income) {\n  riskScore += 1;\n  factors.push(\"Loan Amount exceeds Annual Income\");\n}\n\nconst flagged = riskScore >= 4;\n\nreturn [{\n  json: {\n    ...app,\n    risk_score: riskScore,\n    risk_factors: factors,\n    flagged\n  }\n}];"
      },
      "name": "Risk Scoring Engine",
      "type": "n8n-nodes-base.code",
      "position": [
