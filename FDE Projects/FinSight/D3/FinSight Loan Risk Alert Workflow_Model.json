        "text": "={{`🚨 HIGH RISK LOAN APPLICATION\nLoan ID: ${$json.loan_id}\nBranch: ${$json.branch}\nLoan Purpose: ${$json.loan_purpose}\nRisk Score: ${$json.risk_score}\nTriggered Factors:${$json.risk_factors.join(\", \")}\nRecommended Action:Verify income with employer and request 3 months bank statements.`}}",
        "otherOptions": {}
