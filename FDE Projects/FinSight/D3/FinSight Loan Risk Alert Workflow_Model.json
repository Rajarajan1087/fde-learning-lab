    {
      "parameters": {
        "sendTo": "={{$json.branch_manager_email}}",
        "subject": "=High-Risk Application — Action Required: {{$json.loan_id}}",
        "message": "=<p>Dear Branch Manager,</p>\n\n<p>A high-risk loan application has been detected.</p>\n\n<b>Loan ID:</b> {{$json.loan_id}}<br>\n<b>Branch:</b> {{$json.branch}}<br>\n<b>Risk Score:</b> {{$json.risk_score}}<br>\n\n<b>Risk Factors:</b>\n<ul>\n<li>{{$json.risk_factors.join(\"</li><li>\")}}</li>\n</ul>\n\n<p>\nRisk Tier: HIGH\n</p>\n\n<p>\nThe applicant shows elevated default risk due to multiple adverse indicators.\nBefore approval, verify income with employer, obtain the last three months of bank statements, and consider reducing the sanctioned loan amount.\n</p>\n\n<p>\nRegards,<br>\nFinSight Risk Monitoring System\n</p>",
        "options": {}
      },
