    {
      "parameters": {
        "jsCode": "const rawData = $input.first().json.data;\nconst rows = rawData.split('\\n');\nconst headers = rows[0].split(',');\n\nlet nullCreditScore = 0;\nlet nullDefaultFlag = 0;\nlet negativeRevenue = 0;\nlet totalRows = 0;\n\nfor (let i = 1; i < rows.length; i++) {\n  if (!rows[i].trim()) continue;\n  const cols = rows[i].split(',');\n  totalRows++;\n  \n  const creditScore = cols[headers.indexOf('credit_score')];\n  const defaultFlag = cols[headers.indexOf('default_flag')];\n  const revenue = parseFloat(cols[headers.indexOf('annual_revenue_usd')]);\n  \n  if (!creditScore || creditScore.trim() === '') nullCreditScore++;\n  if (!defaultFlag || defaultFlag.trim() === '') nullDefaultFlag++;\n  if (!isNaN(revenue) && revenue < 0) negativeRevenue++;\n}\n\nconst status = (nullCreditScore > 0 || nullDefaultFlag > 0 || negativeRevenue > 0) ? 'BLOCKED' : 'OK';\n\nreturn [{\n  json: {\n    status,\n    totalRows,\n    nullCreditScore,\n    nullDefaultFlag,\n    negativeRevenue\n  }\n}];"
      },
