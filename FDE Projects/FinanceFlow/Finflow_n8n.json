    {
      "parameters": {
        "jsCode": "const rows = items; // n8n passes parsed rows as items\nlet counts = { Approve: 0, Review: 0, Decline: 0 };\nlet valueAtRisk = 0;\n\nrows.forEach(item => {\n  const decision = item.json.decision;\n  const loanAmount = parseFloat(item.json.loan_amount_usd);\n\n  if (decision === \"Approve\") counts.Approve++;\n  else if (decision === \"Review\") {\n    counts.Review++;\n    valueAtRisk += loanAmount;\n  }\n  else if (decision === \"Decline\") {\n    counts.Decline++;\n    valueAtRisk += loanAmount;\n  }\n});\n\nreturn [{\n  json: {\n    Approve: counts.Approve,\n    Review: counts.Review,\n    Decline: counts.Decline,\n    ValueAtRiskUSD: valueAtRisk\n  }\n}];\n"
      },
